{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "web",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "tags": [
    "type:app",
    "scope:web"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/build",
        "{projectRoot}/.svelte-kit"
      ],
      "options": {
        "command": "vite build",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "db-generate",
        "^build"
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite dev",
        "cwd": "{projectRoot}"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview",
        "cwd": "{projectRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node build",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "^typecheck"
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "db-generate"
      ]
    },
    "coverage": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "options": {
        "command": "vitest run --coverage",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "db-generate"
      ]
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        "build"
      ]
    },
    "db-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate --schema ./prisma/schema.prisma",
        "cwd": "{projectRoot}"
      }
    },
    "db-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma db push --schema ./prisma/schema.prisma",
        "cwd": "{projectRoot}"
      }
    },
    "db-studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma studio --schema ./prisma/schema.prisma",
        "cwd": "{projectRoot}"
      }
    }
  }
}
