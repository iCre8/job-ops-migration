// schema.prisma
// Job-Ops Migration — MongoDB + Prisma v6/v7
//
// IMPORTANT: MongoDB connector does not support `prisma migrate`.
// Apply all schema changes with: npx prisma db push
// Record every change in SCHEMA_CHANGELOG.md before pushing.
//
// Referential actions (onDelete/onUpdate) are NOT enforced by MongoDB.
// Cascades must be handled in application code (repositories/services).

generator client {
  provider = "prisma-client-js"
}

// Prisma v6: URL set via DATABASE_URL env var.
// ISSUE-001: Prisma v7 has no MongoDB adapter — using v6 until @prisma/adapter-mongodb
// is published. Upgrade path tracked in Status.md Decisions Log.
datasource db {
  provider = "mongodb"
}

// ─── Embedded Types ────────────────────────────────────────────────────────────
// Embedded types are stored as sub-documents inside their parent collection.
// They do NOT have their own collection. IDs are generated by application code
// as UUIDs (crypto.randomUUID()) — not auto-generated by MongoDB.

type StageEvent {
  id        String
  stage     String   // ApplicationStage value
  timestamp DateTime
  note      String?
}

type ApplicationTask {
  id          String
  type        String   // prep | todo | follow_up | check_status
  title       String
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime
}

type InterviewRecord {
  id          String
  type        String   // recruiter_screen | technical | onsite | panel | behavioral | final
  scheduledAt DateTime?
  completedAt DateTime?
  outcome     String?  // pass | fail | pending | cancelled
  notes       String?
  createdAt   DateTime
}

type TracerLink {
  id          String
  token       String   // unique random token embedded in PDF
  label       String?
  clickCount  Int      @default(0)
  lastClickAt DateTime?
  createdAt   DateTime
}

type ChatMessage {
  id        String
  role      String   // user | assistant | system
  content   String
  createdAt DateTime
}

type SyncRun {
  id            String
  status        String    // running | completed | failed
  messagesFound Int       @default(0)
  startedAt     DateTime
  completedAt   DateTime?
  error         String?
}

// ─── Collections ───────────────────────────────────────────────────────────────

model Job {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Source / discovery ──
  source     String          // jobspy | gradcracker | ukvisajobs | adzuna | manual
  externalId String?         // ID from the originating job board
  url        String?
  crawledAt  DateTime?

  // ── Core fields ──
  title       String
  employer    String?
  location    String?
  country     String?
  isRemote    Boolean @default(false)
  jobType     String? // full_time | part_time | contract | internship
  salaryMin   Float?
  salaryMax   Float?
  salaryCurrency String?
  salaryPeriod   String?
  jobDescription String?
  benefits       String?

  // ── Lifecycle status ──
  // discovered → processing → ready → applied → in_progress | skipped | expired
  status String @default("discovered")

  // ── AI scoring ──
  scoreOverall   Float?
  scoreReasoning String?
  scoredAt       DateTime?

  // ── AI tailoring ──
  tailoredSummary  String?
  tailoredHeadline String?
  tailoredSkills   String?  // JSON-serialised string[]
  tailoredAt       DateTime?
  selectedProjectIds String? // JSON-serialised string[]

  // ── PDF / storage ──
  pdfPath       String?  // legacy local path (kept for migration reference)
  pdfStorageKey String?  // DO Spaces object key: resume_{id}.pdf
  pdfPublicUrl  String?  // CDN or signed base URL
  pdfGeneratedAt DateTime?

  // ── Application tracking ──
  applicationStage   String?  // ApplicationStage value
  applicationOutcome String?  // offer_accepted | offer_declined | rejected | withdrawn | no_response | ghosted
  appliedAt          DateTime?
  applicationUrl     String?
  applicationNote    String?
  deadline           DateTime?

  // ── Tracer ──
  tracerLinksEnabled Boolean @default(false)

  // ── JobSpy enrichment ──
  companyIndustry  String?
  companyUrl       String?
  companyLogo      String?
  companySector    String?
  companyRevenue   String?
  companyEmployees String?
  linkedinId       String?
  indeedId         String?
  glassdoorId      String?
  emails           String? // JSON-serialised string[]
  personName       String?
  visaSponsor      Boolean?

  // ── Embedded child documents ──
  stageEvents StageEvent[]
  tasks       ApplicationTask[]
  interviews  InterviewRecord[]
  tracerLinks TracerLink[]

  // ── Relations (separate collections) ──
  chatThreads ChatThread[]
  clickEvents TracerClickEvent[]

  @@index([status])
  @@index([crawledAt])
  @@index([employer])
  @@index([source])
  @@map("jobs")
}

model TracerClickEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String   @db.ObjectId
  linkToken String
  ip        String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([linkToken])
  @@index([clickedAt])
  @@map("tracer_click_events")
}

model PipelineRun {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  status      String    // running | completed | failed | partial
  triggeredBy String    // scheduler | manual | webhook
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  jobsFound   Int       @default(0)
  jobsScored  Int       @default(0)
  jobsSkipped Int       @default(0)
  error       String?
  meta        Json?

  @@index([startedAt])
  @@index([status])
  @@map("pipeline_runs")
}

model ChatThread {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  jobId     String        @db.ObjectId
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  job      Job       @relation(fields: [jobId], references: [id])
  chatRuns ChatRun[]

  @@index([jobId])
  @@map("chat_threads")
}

model ChatRun {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  threadId     String    @db.ObjectId
  jobId        String    @db.ObjectId
  status       String    // running | completed | failed
  model        String
  promptTokens Int?
  outputTokens Int?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  error        String?

  thread ChatThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
  @@index([jobId])
  @@map("chat_runs")
}

model Settings {
  // Singleton — application always queries findFirst() and upserts with id="singleton".
  // The `data` field holds all settings as a JSON object.
  id        String   @id @map("_id")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model PostApplicationIntegration {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  provider     String    // gmail
  status       String    // not_configured | connecting | connected | disconnected
  email        String?
  // Tokens are stored encrypted — never log raw values
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  syncRuns     SyncRun[]

  messages PostApplicationMessage[]

  @@map("post_application_integrations")
}

model PostApplicationMessage {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  integrationId  String    @db.ObjectId
  externalId     String    // Gmail message ID — used to prevent duplicates
  subject        String?
  fromAddress    String?
  receivedAt     DateTime?
  // AI classification
  classification String?   // interview_invite | rejection | offer | follow_up | other
  relevance      String?   // high | medium | low
  // Inbox review
  linkedJobId    String?   @db.ObjectId
  approved       Boolean?
  reviewedAt     DateTime?
  rawSnippet     String?   // Truncated preview — never store full email body
  createdAt      DateTime  @default(now())

  integration PostApplicationIntegration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([linkedJobId])
  @@index([receivedAt])
  @@index([externalId])
  @@map("post_application_messages")
}
