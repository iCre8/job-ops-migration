# apps/web local environment
# Copy to apps/web/.env for local Prisma, SvelteKit, and Nx project commands.

DATABASE_URL="mongodb://localhost:27017/jobops?directConnection=true&replicaSet=rs0"

# Required by pnpm db:seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-this-password
SEED_ADMIN_DISPLAY_NAME=Admin

# Optional auth settings
# JWT_SECRET=change-this-to-at-least-32-characters
# JWT_EXPIRY_SECONDS=86400
