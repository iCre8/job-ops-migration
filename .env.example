# .env.example — Job-Ops Migration
# Copy to .env and fill in your values before running docker compose up.
# Never commit .env to version control.

# ─── MongoDB (Docker Compose — self-hosted) ───────────────────────────────────
MONGO_USER=jobops
MONGO_PASSWORD=changeme_strong_password

# Constructed automatically from MONGO_USER/MONGO_PASSWORD in docker-compose.yml.
# Only set DATABASE_URL directly if running outside Docker Compose (e.g. local dev).
# DATABASE_URL=mongodb://jobops:changeme@localhost:27017/jobops?authSource=admin

# ─── DigitalOcean Spaces (S3-compatible object storage) ─────────────────────
# Bucket must exist and credentials must have read/write access.
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_BUCKET=jobops-resumes
# Optional: CDN endpoint (faster PDF downloads, no egress cost)
DO_SPACES_CDN_URL=

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Compatible with OpenRouter, OpenAI, Gemini, etc.
# OpenRouter format: "provider/model-name" (e.g. google/gemini-flash-1.5)
LLM_API_KEY=your_llm_api_key
MODEL=google/gemini-flash-1.5

# ─── RxResume (PDF generation) ───────────────────────────────────────────────
# Self-hosted or public instance. v4 uses email/password; v5 uses API key.
RXRESUME_URL=https://v4.rxresu.me
RXRESUME_EMAIL=your@email.com
RXRESUME_PASSWORD=your_rxresume_password

# ─── Web Server ───────────────────────────────────────────────────────────────
WEB_PORT=3005

# Optional: Basic Auth to protect write endpoints (leave blank to disable)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# ─── Gmail OAuth (post-application tracking) ─────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Must match the redirect URI configured in Google Cloud Console
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3005/oauth/gmail/callback

# ─── Tracer Links ─────────────────────────────────────────────────────────────
# Public-facing URL used in PDF tracer links. Must be reachable from the internet.
JOBOPS_PUBLIC_BASE_URL=https://jobops.example.com

# ─── Extractor Sidecar ────────────────────────────────────────────────────────
# Set automatically via docker-compose.yml (http://extractor:8000).
# Only override when running web service outside Docker.
# EXTRACTOR_URL=http://localhost:8000

# ─── JobSpy (via extractor sidecar) ──────────────────────────────────────────
JOBSPY_IS_REMOTE=0

# ─── Adzuna ───────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_MAX_JOBS_PER_TERM=25
