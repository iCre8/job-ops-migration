{
  "name": "job-ops",
  "version": "0.9.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.1",
  "workspaces": [
    "orchestrator",
    "docs-site",
    "career-boards/*",
    "extractors/*",
    "shared",
    "apps/*"
  ],
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm nx dev orchestrator",
    "dev:server": "pnpm nx dev-server orchestrator",
    "dev:client": "pnpm nx dev-client orchestrator",
    "build": "pnpm nx build orchestrator",
    "start": "pnpm nx start orchestrator",
    "lint": "pnpm nx lint orchestrator",
    "check": "pnpm nx typecheck orchestrator",
    "check:types": "pnpm nx typecheck orchestrator",
    "test": "pnpm nx test orchestrator",
    "test:watch": "pnpm --filter job-ops-orchestrator test",
    "test:all": "pnpm nx test orchestrator",
    "affected:build": "pnpm nx affected --target=build",
    "affected:test": "pnpm nx affected --target=test",
    "affected:check": "pnpm nx affected --target=typecheck",
    "affected:lint": "pnpm nx affected --target=lint",
    "docs:dev": "pnpm --filter docs-site start",
    "docs:build": "pnpm --filter docs-site build",
    "check:docs": "pnpm --filter docs-site build",
    "docs:serve": "pnpm --filter docs-site serve",
    "docs:version": "pnpm --filter docs-site docs:version",
    "typst-theme:generate": "node ./scripts/generate-typst-themes.mjs",
    "typst-theme:validate": "node ./scripts/generate-typst-themes.mjs --check && pnpm --filter job-ops-orchestrator test:run -- src/server/services/resume-renderer/typst.test.ts",
    "release:set-version": "node ./scripts/set-orchestrator-version.mjs",
    "knip": "knip",
    "dep-graph": "pnpm nx graph",
    "dep-graph:export": "pnpm nx graph --file=dep-graph.html"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "knip": "^5.83.1",
    "nx": "19.8.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "22.22.1"
  }
}
